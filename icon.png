from PIL import Image, ImageDraw# Create 192x192 black backgroundimg = Image.new('RGB', (192, 192), color='black')draw = ImageDraw.Draw(img)# Draw a simple pink "brain" shape (abstract)draw.ellipse((32, 32, 160, 160), outline='pink', width=8)draw.line((32, 96, 160, 96), fill='pink', width=4)draw.line((96, 32, 96, 160), fill='pink', width=4)draw.line((48, 48, 144, 144), fill='pink', width=2)draw.line((144, 48, 48, 144), fill='pink', width=2)# Save PNGimg.save("icon.png")